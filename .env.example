# Worker API auth. Set as a Wrangler secret in production.
# npx wrangler secret put ADMIN_API_KEY
ADMIN_API_KEY=change-me

# Optional Pi extension / Claude Code plugin / REST client settings.
ASAKI_MEMORY_BASE_URL=http://127.0.0.1:8787
ASAKI_MEMORY_API_URL=http://127.0.0.1:8787
ASAKI_MEMORY_API_KEY=change-me
ASAKI_MEMORY_USER_ID=default-user
ASAKI_MEMORY_PROJECT_ID=example-project
ASAKI_MEMORY_DIGEST_TOP_K=8
ASAKI_MEMORY_AUTO_INJECT=1
ASAKI_MEMORY_AUTO_EXTRACT=1
ASAKI_MEMORY_AUTO_MIN_SCORE=0.67

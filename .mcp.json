{
  "asaki-memory": {
    "type": "stdio",
    "command": "node",
    "args": [
      "${CLAUDE_PLUGIN_ROOT}/dist/mcp-server.mjs"
    ],
    "env": {
      "ASAKI_MEMORY_SOURCE": "claude-code",
      "ASAKI_MEMORY_BASE_URL": "${ASAKI_MEMORY_BASE_URL}",
      "ASAKI_MEMORY_API_KEY": "${ASAKI_MEMORY_API_KEY}",
      "ASAKI_MEMORY_USER_ID": "asaki"
    }
  }
}

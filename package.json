{
  "name": "asaki-memory-manager",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "start": "wrangler dev --local",
    "typecheck": "tsc --noEmit",
    "eval:candidates": "node --experimental-strip-types scripts/eval-candidates.ts",
    "eval:search": "node --experimental-strip-types scripts/eval-search-scoring.ts",
    "eval:extraction": "bash scripts/eval-extraction.sh",
    "eval:extraction-guardrails": "node --experimental-strip-types scripts/eval-extraction-guardrails.ts",
    "eval:classifier": "bash scripts/eval-classifier.sh",
    "eval:sensitive-pattern": "bash scripts/eval-sensitive-pattern.sh",
    "shadow-run:extraction": "node --experimental-strip-types scripts/shadow-run-extraction.ts",
    "backfill:index": "node --experimental-strip-types scripts/backfill-index.ts",
    "prune:stale": "node --experimental-strip-types scripts/prune-stale.ts",
    "smoke:management": "bash scripts/smoke-management-api.sh",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply asaki-memory-manager --local",
    "db:migrate:remote": "wrangler d1 migrations apply asaki-memory-manager --remote",
    "build:mcp": "esbuild integrations/mcp/asaki-memory.ts --bundle --platform=node --format=esm --outfile=dist/mcp-server.mjs",
    "build:plugin": "npm run build:mcp",
    "build:pi": "node --experimental-strip-types scripts/build-pi-package.ts"
  },
  "dependencies": {
    "hono": "^4.10.7"
  },
  "pi": {
    "extensions": [
      "./integrations/pi/asaki-memory.ts"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251224.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3",
    "wrangler": "^4.105.0",
    "zod": "^3.25.76"
  },
  "description": "Cloudflare-native personal memory layer for AI agents: D1, Vectorize, Workers AI, REST, and Pi integration.",
  "license": "MIT",
  "keywords": [
    "ai-memory",
    "agents",
    "cloudflare-workers",
    "d1",
    "vectorize",
    "workers-ai",
    "hono",
    "typescript"
  ],
  "homepage": "https://github.com/Asaki14/asaki-memory-manager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Asaki14/asaki-memory-manager.git"
  },
  "bugs": {
    "url": "https://github.com/Asaki14/asaki-memory-manager/issues"
  }
}

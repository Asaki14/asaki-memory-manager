{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "asaki-memory-manager",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "EMBEDDING_MODEL": "@cf/baai/bge-m3",
    "MEMORY_LLM_MODEL": "@cf/meta/llama-3.1-8b-instruct-fp8"
  },
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "asaki-memory-manager",
      "database_id": "replace-with-your-d1-database-id"
    }
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "asaki-memory-manager"
    }
  ],
  // Rate limiting for the expensive routes (search/candidates/extract) that trigger
  // Workers AI embeddings/LLM calls and Vectorize queries. namespace_id is a free-form
  // identifier — no Cloudflare dashboard setup needed, just keep it stable per binding.
  // Tune simple.limit/simple.period to taste; 30 req/min per user_id is a starting point
  // for single-operator use.
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 30, "period": 60 }
    }
  ]
}
